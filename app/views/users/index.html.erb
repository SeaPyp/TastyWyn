<h1>Good to see you again, <%= @user.first_name.titleize %></h1>

<% if @user.posts.count > 0 %>
  <p>Here is the last wine you drank:</p>

  <%= @user.posts.last.title %>
  <%= @user.posts.last.text %>
  <%= @user.posts.last.rating %>
  <%= image_tag @user.posts.last.image.url(:large) %>
<% else %>
  <p>You haven't had any wine yet. What are you waiting for?</p>
<% end %>
<br>

<%= link_to '<button>Create New Post</button>'.html_safe, new_post_path %>

<table>
  <tr>
      <th>Title</th>
      <th>Text</th>
      <th colspan='3'></th>
    </tr>

  <% @user.posts.each do |post| %>
    <tr>
      <td><%= post.title %></td>
      <td><%= post.text %></td>
      <td><%= post.rating %></td>
      <td><%= link_to 'Show', post_path(post) %></td>
      <td><%= link_to 'Edit', edit_post_path(post) %></td>
       <td><%= link_to 'Destroy', post_path(post),
              method: :delete,
              data: { confirm: 'Are you sure?' } %></td>
    </tr>

  <% end %>
</table>

<%= link_to 'Log Out', logout_path, method: :delete %>
