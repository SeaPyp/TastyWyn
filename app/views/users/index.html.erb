<h1>Good to see you again, <%= @user.first_name.titleize %></h1>

<% if @user.posts.any? %>
  <p>Here is the last wine you drank:</p>
  <p><%= @user.posts.last.title %></p>
  <p><%= @user.posts.last.text %></p>
  <p>Rating: <%= @user.posts.last.rating %>/10</p>
  <%= image_tag @user.posts.last.image if @user.posts.last.image.attached? %>
<% else %>
  <p>You haven't had any wine yet. What are you waiting for?</p>
<% end %>

<br>
<%= link_to 'Create New Post', new_post_path %>

<table>
  <tr>
    <th>Title</th>
    <th>Tasting Notes</th>
    <th>Rating</th>
    <th colspan='3'></th>
  </tr>
  <% @user.posts.each do |post| %>
    <tr>
      <td><%= post.title %></td>
      <td><%= post.text %></td>
      <td><%= post.rating %>/10</td>
      <td><%= link_to 'Show', post_path(post) %></td>
      <td><%= link_to 'Edit', edit_post_path(post) %></td>
      <td><%= link_to 'Delete', post_path(post), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %></td>
    </tr>
  <% end %>
</table>

<%= link_to 'Log Out', logout_path, data: { turbo_method: :delete } %>
